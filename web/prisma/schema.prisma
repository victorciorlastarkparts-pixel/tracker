generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  activities   Activity[]
  deviceAssignments DeviceAssignment[]
}

model DeviceAssignment {
  id         String   @id @default(cuid())
  deviceName String   @unique
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String
  deviceName  String
  appName     String
  processName String
  windowTitle String
  url         String?
  urlDomain   String?
  startUtc    DateTime
  endUtc      DateTime
  durationMs  Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startUtc])
  @@index([userId, appName])
  @@index([userId, urlDomain])
}
