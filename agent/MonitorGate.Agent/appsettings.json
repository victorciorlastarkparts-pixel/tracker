{
  "Agent": {
    "UserId": "endmin-root",
    "DeviceName": "windows-main",
    "PollIntervalMs": 1000,
    "SyncIntervalSeconds": 120,
    "ForegroundSliceSeconds": 2,
    "IdleThresholdSeconds": 40,
    "BatchSize": 300,
    "ApiBaseUrl": "https://your-vercel-app.vercel.app",
    "ApiToken": "replace-with-secure-token",
    "SendFullUrl": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
